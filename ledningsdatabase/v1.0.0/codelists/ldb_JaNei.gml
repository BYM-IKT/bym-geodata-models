<?xml version="1.0" encoding="utf-8"?>
<gml:Dictionary xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:gml="http://www.opengis.net/gml/3.2" xsi:schemaLocation="http://www.opengis.net/gml/3.2 http://schemas.opengis.net/gml/3.2.1/gml.xsd" gml:id="ldb_JaNei">
  <gml:metaDataProperty>
    <gml:GenericMetaData>
      <status>submitted</status>
      <lastUpdated>2026-03-17T10:33:04</lastUpdated>
    </gml:GenericMetaData>
  </gml:metaDataProperty>
  <gml:description>Kodeliste som uttrykker binære tilstander (ja/nei), med støtte for ukjent informasjon og irrelevante tilfeller. Brukes i situasjoner der boolsk verdi ikke er tilstrekkelig, og det er behov for å skille mellom “nei”, “vet ikke” og “ikke aktuelt”.</gml:description>
  <gml:identifier codeSpace="">JaNei</gml:identifier>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="JaNei.ja">
      <gml:description>Tilstanden gjelder / er aktiv / valgt / oppfylt</gml:description>
      <gml:identifier codeSpace="#JaNei.ja">ja</gml:identifier>
      <gml:name>Ja</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="JaNei.nei">
      <gml:description>ilstanden gjelder ikke / er inaktiv / ikke valgt</gml:description>
      <gml:identifier codeSpace="#JaNei.nei">nei</gml:identifier>
      <gml:name>Nei</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
</gml:Dictionary>