<?xml version="1.0" encoding="utf-8"?>
<gml:Dictionary xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:gml="http://www.opengis.net/gml/3.2" xsi:schemaLocation="http://www.opengis.net/gml/3.2 http://schemas.opengis.net/gml/3.2.1/gml.xsd" gml:id="ldb_Merketype">
  <gml:metaDataProperty>
    <gml:GenericMetaData>
      <status>submitted</status>
      <lastUpdated>2026-05-18T11:12:53</lastUpdated>
    </gml:GenericMetaData>
  </gml:metaDataProperty>
  <gml:description>Angir hvordan kummen er fysisk merket innvendig. Verdien «Ingen» betyr at objektet ikke er merket. Øvrige verdier beskriver type merking, for eksempel merkeplate eller maling/spraymerking. Verdien velges fra kodeliste.</gml:description>
  <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml">Merketype</gml:identifier>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Merketype.annet">
      <gml:description>Brukes når objektet er merket på annen måte – spesifiseres i infofeltet.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml#Merketype.annet">annet</gml:identifier>
      <gml:name>Annet</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Merketype.gravering">
      <gml:description>Innrisset eller gravert merke i kum  eller for rør  fra fabrikk</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml#Merketype.gravering">gravering</gml:identifier>
      <gml:name>Gravering</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Merketype.ingen">
      <gml:description>Objektet er ikke fysisk merket.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml#Merketype.ingen">ingen</gml:identifier>
      <gml:name>Ingen</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Merketype.merkeplate">
      <gml:description>Metall- eller plastplate festet på eller ved objektet. Merkeplaten skal merkes iht. ledningseiers krav.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml#Merketype.merkeplate">merkeplate</gml:identifier>
      <gml:name>Merkeplate</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Merketype.spraymaling">
      <gml:description>Objeket/Element er merket med spraymaling</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml#Merketype.spraymaling">spraymaling</gml:identifier>
      <gml:name>SprayMaling</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
</gml:Dictionary>