<?xml version="1.0" encoding="utf-8"?>
<gml:Dictionary xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:gml="http://www.opengis.net/gml/3.2" xsi:schemaLocation="http://www.opengis.net/gml/3.2 http://schemas.opengis.net/gml/3.2.1/gml.xsd" gml:id="ldb_Målemetode">
  <gml:metaDataProperty>
    <gml:GenericMetaData>
      <status>submitted</status>
      <lastUpdated>2026-05-18T15:07:00</lastUpdated>
    </gml:GenericMetaData>
  </gml:metaDataProperty>
  <gml:description>Metode eller instrument brukt for innmåling av horisontal posisjon (X/Y). Velges fra standardisert kodeliste.</gml:description>
  <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml">Målemetode</gml:identifier>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.digitalisertPaaSkjermFraAndreDigitaleRasterdata">
      <gml:description>posisjon digitalisert på skjerm fra andre kilder enn ortofoto eller satellittbilder</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml#Målemetode.digitalisertPaaSkjermFraAndreDigitaleRasterdata">digitalisertPaaSkjermFraAndreDigitaleRasterdata</gml:identifier>
      <gml:name>digitalisertPåSkjermFraAndreDigitaleRasterdata</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.digitalisertPaaSkjermFraOrtofoto">
      <gml:description>posisjon overført fra ortofoto ved hjelp av manuell registrering på skjerm</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml#Målemetode.digitalisertPaaSkjermFraOrtofoto">digitalisertPaaSkjermFraOrtofoto</gml:identifier>
      <gml:name>digitalisertPåSkjermFraOrtofoto</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.digitalisertPaaSkjermFraSkannetKart">
      <gml:description>posisjon overført fra kart ved hjelp av manuell registrering på skjerm, medium skannet kart (raster), samkopi</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml#Målemetode.digitalisertPaaSkjermFraSkannetKart">digitalisertPaaSkjermFraSkannetKart</gml:identifier>
      <gml:name>digitalisertPåSkjermFraSkannetKart</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.frihaandstegningPaaSkjerm">
      <gml:description>posisjon  digitalisert ut fra frihåndstegning (direkte på skjerm), frihåndstegning er basert på svært grovt grunnlag eller ikke noe grunnlag</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml#Målemetode.frihaandstegningPaaSkjerm">frihaandstegningPaaSkjerm</gml:identifier>
      <gml:name>frihåndstegningPåSkjerm</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.genererteDataFraAnnenGeometri">
      <gml:description>posisjon generert, sirkelgeometri, korridor eller annen geometri er generert ut fra f.eks et punkt eller en linje (f.eks midtlinje veg)</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml#Målemetode.genererteDataFraAnnenGeometri">genererteDataFraAnnenGeometri</gml:identifier>
      <gml:name>genererteDataFraAnnenGeometri</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.genererteDataSentralpunkt">
      <gml:description>posisjon generert, sentralpunkt</gml:description>
