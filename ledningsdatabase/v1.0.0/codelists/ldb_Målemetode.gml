      <gml:name>genererteDataSentralpunkt</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Målemetode.GNSSFasemaalingFloatLoesning">
      <gml:description>posisjon  innmålt med satellittbaserte systemer for navigasjon og posisjonering med global dekning (f.eks GPS, GLONASS, GALILEO). Fasemåling float-løsning</gml:description>
