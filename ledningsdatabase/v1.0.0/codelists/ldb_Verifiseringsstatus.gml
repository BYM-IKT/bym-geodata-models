<?xml version="1.0" encoding="utf-8"?>
<gml:Dictionary xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:gml="http://www.opengis.net/gml/3.2" xsi:schemaLocation="http://www.opengis.net/gml/3.2 http://schemas.opengis.net/gml/3.2.1/gml.xsd" gml:id="ldb_Verifiseringsstatus">
  <gml:metaDataProperty>
    <gml:GenericMetaData>
      <status>submitted</status>
      <lastUpdated>2026-06-08T14:40:24</lastUpdated>
    </gml:GenericMetaData>
  </gml:metaDataProperty>
  <gml:description>kodeliste for verifiseringsstatus som beskriver i hvilken grad et objekt har vært mulig å kontrollere i felt. Kodelisten skal brukes i tilfeller der forhold som dårlig sikt, vannfylte kummer eller andre hindringer påvirker muligheten til å verifisere objektet.</gml:description>
  <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Verifiseringsstatus.gml">Verifiseringsstatus</gml:identifier>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Verifiseringsstatus.verifisert">
      <gml:description>Objektet er observert og bekreftet i felt.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Verifiseringsstatus.gml#Verifiseringsstatus.verifisert">verifisert</gml:identifier>
      <gml:name>Verifisert</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Verifiseringsstatus.delvisVerifisert">
      <gml:description>Objektet er delvis observert, men ikke alle detaljer kunne bekreftes.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Verifiseringsstatus.gml#Verifiseringsstatus.delvisVerifisert">delvisVerifisert</gml:identifier>
      <gml:name>Delvis verifisert</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
  <gml:dictionaryEntry>
    <gml:Definition gml:id="Verifiseringsstatus.ikkeMuligVerifisere">
      <gml:description>Objektet kunne ikke kontrolleres p&amp;#229; grunn av forhold i felt.</gml:description>
      <gml:identifier codeSpace="forskjellige URL -https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Verifiseringsstatus.gml#Verifiseringsstatus.ikkeMuligVerifisere">ikkeMuligVerifisere</gml:identifier>
      <gml:name>Ikke mulig å verifisere</gml:name>
    </gml:Definition>
  </gml:dictionaryEntry>
</gml:Dictionary>