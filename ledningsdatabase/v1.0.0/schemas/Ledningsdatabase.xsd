	</complexType>
	<element name="Fundament" type="ldb:FundamentType" abstract="true" substitutionGroup="ldb:Kopling">
		<annotation>
			<documentation>Fysisk konstruksjon som utgjør et terminering- eller monteringspunkt for ulike komponenter i infrastrukturen, som skap, lysmaster, p-automater og bommer. 

	Fundamentelementer er ofte prefabrikkerte og benyttes der det kreves varig og stabil forankring. Fundamenter kan være sluttpunkt for traseer, rør eller kabler.

	Type fundament spesifiseres med kodelisten `FundamentType`.

Geometrisk punkt som representerer topp senterpunkt av fundamentet i horisontalplanet. Punktet brukes som posisjon i kart og inkluderer posisjonskvalitet.</documentation>
		</annotation>
	</element>
	<complexType name="FundamentType" abstract="true">
		<complexContent>
			<extension base="ldb:KoplingType">
				<sequence>
					<element name="omriss" type="ldb:PolygongeometriPropertyType">
						<annotation>
							<documentation>Omriss: Polygon som representerer fundament omriss og flateutbredelse i terrenget. Geometrien benyttes for korrekt visning, rotasjon og posisjonering, og inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="FundamentPropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Fundament"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
