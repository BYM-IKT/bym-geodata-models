			<documentation>Angir farge på trekkerøret. Verdien velges fra kodeliste og brukes til å identifisere eier og/eller funksjon.</documentation>
		</annotation>
		<union memberTypes="ldb:TrekkerørFargeEnumerationType ldb:TrekkerørFargeOtherType"/>
	</simpleType>
