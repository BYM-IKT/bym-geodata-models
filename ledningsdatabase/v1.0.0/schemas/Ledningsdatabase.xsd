			<enumeration value="0">
				<annotation>
					<documentation>Objektet er fullt ut synlig/gjenfinnbart i flybilde eller annen datakilde for posisjonering. Ved fotogrammetrisk registrering skal objekter som er fullt ut synlige registreres i tråd med angitte krav til nøyaktig registrering.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="3">
				<annotation>
					<documentation>Objektet er ikke synlig/gjenkjennbart i flybilde eller annen datakilde for posisjonering. Ved fotogrammetrisk datafangst brukes denne koden for objekter som er helt skjult av overliggende objekter (vegetasjon, takoverbygg, bruer etc.). For slike objekter settes en stor verdi for nøyaktighet (mer enn 3 ganger kravet)</documentation>
				</annotation>
			</enumeration>
			<enumeration value="2">
				<annotation>
					<documentation>Objektet er middels synlig/gjenkjennbart i flybilde eller annen datakilde for posisjonering. Ved fotogrammetrisk datafangst brukes denne koden for objekter som har lav kontrast eller er delvis skjult av overliggende objekter (vegetasjon, takoverbygg, bruer etc.). For slike objekter settes en større verdi for nøyaktighet enn kravet (opptil 3 ganger kravet)</documentation>
				</annotation>
			</enumeration>
		</restriction>
	</simpleType>
	<simpleType name="SynbarhetOtherType">
		<restriction base="string">
			<pattern value="other: \w{2,}"/>
		</restriction>
	</simpleType>
	<element name="Trase" type="ldb:TraseType" substitutionGroup="gml:AbstractFeature">
		<annotation>
			<documentation>Trasè representerer en senterlinje for én eller flere trekkerør mellom to termineringspunkter. Alle rør innenfor samme trasè skal ha felles start- og endepunkt. 
Dersom flere rør ligger i samme grøft eller kanal, men terminerer i ulike endepunkter, skal disse registreres som separate traseer. Det kan derfor forekomme flere parallelle traseer innenfor samme grøft eller kanal.
Trasèen registreres som en linjegeometri langs senter av grøft eller kanal, uavhengig av antall rør som ligger i føringsveien. Trasèen kan inneholde avbøyninger, men representerer én sammenhengende forbindelse mellom samme start- og endepunkt.</documentation>
		</annotation>
	</element>
	<complexType name="TraseType">
		<complexContent>
			<extension base="gml:AbstractFeatureType">
				<sequence>
					<element name="linje" type="ldb:LinjegeometriPropertyType">
						<annotation>
							<documentation>Linje: Linje som representerer senterlinje for trase mellom felles start- og endepunkt. Inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
					<element name="antallRørEiesAvBYM" type="integer">
						<annotation>
							<documentation>Antall BYM-rør: Antall rør eller trekkerør i traseen som eies av Bymiljøetaten. Oppgis som heltall.</documentation>
						</annotation>
					</element>
					<element name="antallRørEiesAvAndre" type="integer">
						<annotation>
							<documentation>Antall eksterne rør: Antall rør som eies av andre aktører i traseen. Oppgis som heltall.</documentation>
						</annotation>
					</element>
					<element name="merknad" type="string" minOccurs="0"/>
					<element name="navn" type="string" minOccurs="0">
						<annotation>
							<documentation>Navn: Angir en formell betegnelse eller identifikator som kan brukes til å navngi objektet i henhold til standarder eller eksterne krav._x000D_
Verdien er valgfri, men skal kun benyttes der det finnes et etablert navn eller nummer fra eksterne kilder (for eksempel prosjektdokumentasjon eller registre)._x000D_
Attributtet er ikke ment for plassering, merknader eller annen beskrivende informasjon.</documentation>
						</annotation>
					</element>
					<element name="uuid" type="string" minOccurs="0">
						<annotation>
							<documentation>Objekt-ID: Universell unik identifikator (GUID) for objektet. Verdien genereres automatisk og sikrer global entydighet på tvers av systemer og databaser. Brukes til å koble objekter på tvers av datasett og forvaltningssystemer, og endres ikke selv om andre egenskaper ved objektet oppdateres.</documentation>
						</annotation>
					</element>
					<element name="komponenter" type="ldb:NettverkskomponentPropertyType" minOccurs="0" maxOccurs="unbounded">
						<annotation>
							<appinfo>
								<reversePropertyName xmlns="http://www.opengis.net/gml/3.2">ldb:trase</reversePropertyName>
							</appinfo>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="TrasePropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Trase"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
	<element name="Trekkekum" type="ldb:TrekkekumType" substitutionGroup="ldb:Kopling">
		<annotation>
			<documentation>Et fysisk objekt, vanligvis laget av stål, plast eller betong, som er gravd ned i bakken for å skape et lukket rom. Inne i kummen finnes koplinger, koblingspunkter eller skjøter hvor ledninger, kabler eller rør fra et nettverk er tilkoblet. Kummen gir tilgang til disse forbindelsene for inspeksjon, vedlikehold og reparasjon uten behov for å grave opp bakken. Kummen registreres med polygongeometri som representerer kummens omriss og utstrekning i terrenget. Høyde refereres til bunn innvendig kum. For runde kummer registreres omriss basert på bunn kum, og diameter oppgis som egen verdi.</documentation>
		</annotation>
	</element>
	<complexType name="TrekkekumType">
		<complexContent>
			<extension base="ldb:KoplingType">
				<sequence>
					<element name="omriss" type="ldb:PolygongeometriPropertyType">
						<annotation>
							<documentation>Omriss: Polygon som representerer kummens omriss bunn kum. Geometrien benyttes for korrekt visning, rotasjon og posisjonering, og inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
					<element name="trekkekumform" type="ldb:TrekkekumFormType">
						<annotation>
							<documentation>Kumform: Angir kummens form, for eksempel rund, kvadratisk eller Ågekorskum. Verdien velges fra kodelisten TrekkekumFrom.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_TrekkekumForm.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="merking" type="ldb:MerketypeType">
						<annotation>
							<documentation>Merking: Angir hvordan kummen er fysisk merket innvendig. Verdien «Ingen» betyr at objektet ikke er merket. Øvrige verdier beskriver type merking, for eksempel merkeplate eller maling/spraymerking. Verdien velges fra kodeliste.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="antallRørEiesAvBYM" type="integer">
						<annotation>
							<documentation>Antall BYM-rør: Angir antall rør i kummen som eies av Bymiljøetaten. Oppgis som heltall. Dersom kummen inneholder oransje rør, regnes kummen som eid av BYM selv om andre aktører også har rør terminert i kummen.</documentation>
						</annotation>
					</element>
					<element name="antallRørEiesAvAndre" type="integer">
						<annotation>
							<documentation>Antall eksterne rør: Angir antall rør i kummen som eies av andre aktører enn BYM. Oppgis som heltall. Informasjon om rørfarge og eier registreres under objektet «trekkerør».</documentation>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="TrekkekumPropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Trekkekum"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
	<simpleType name="TrekkekumFormType">
		<annotation>
			<documentation>Angir kummens form, for eksempel rund, kvadratisk eller Ågekorskum. Verdien velges fra kodelisten Kumformtype.</documentation>
		</annotation>
		<union memberTypes="ldb:TrekkekumFormEnumerationType ldb:TrekkekumFormOtherType"/>
	</simpleType>
	<simpleType name="TrekkekumFormEnumerationType">
