		</restriction>
	</simpleType>
	<element name="Trekkerør" type="ldb:TrekkerørType" substitutionGroup="ldb:Fremføringslinje">
		<annotation>
			<documentation>Alle nye trekkerør som etableres for BYM skal registreres. Primært skal ledningsdatabasen dokumentere BYM sine oransje trekkerør.
Trekkerør registreres som egne objekter med linjegeometri som representerer plasseringen til hvert enkelt rør i en trasè. Tilhørende informasjon om eier, rørfarge og dimensjon registreres på hvert trekkerør.</documentation>
		</annotation>
	</element>
	<complexType name="TrekkerørType">
		<complexContent>
			<extension base="ldb:FremføringslinjeType">
				<sequence>
					<element name="diameter" type="ldb:TrekkerørDiameterType">
						<annotation>
							<documentation>Diameter (mm): Angir dimensjon på trekkerøret. Verdien velges fra kodeliste.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_TrekkerørDiameter.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="merking" type="ldb:MerketypeType" minOccurs="0">
						<annotation>
							<documentation>Merking: Angir hvordan objektet (kum, rør eller trase) er fysisk merket i terrenget. Verdien velges fra kodelisten Merketype._x000D_
Verdien Ingen betyr at objektet ikke er merket. Øvrige verdier beskriver hvilken type merking som er benyttet, for eksempel merkeplate eller maling/spraymerking. Informasjonen brukes til drift, kontroll og dokumentasjon.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Merketype.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="rørfarge" type="ldb:TrekkerørFargeType">
						<annotation>
							<documentation>Rørfarge: Angir farge på trekkerøret. Verdien velges fra kodeliste og brukes til å identifisere eier og/eller funksjon.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_TrekkerørFarge.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="TrekkerørPropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Trekkerør"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
	<simpleType name="TrekkerørDiameterType">
		<annotation>
			<documentation>Angir dimensjon på trekkerøret. Verdien velges fra kodeliste.</documentation>
		</annotation>
		<union memberTypes="ldb:TrekkerørDiameterEnumerationType ldb:TrekkerørDiameterOtherType"/>
	</simpleType>
	<simpleType name="TrekkerørDiameterEnumerationType">
