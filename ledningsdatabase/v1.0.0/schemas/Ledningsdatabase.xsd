	<element name="Polygongeometri" type="ldb:PolygongeometriType" substitutionGroup="gml:AbstractObject">
		<annotation>
			<documentation>Datatypen brukes for å strukturere og beskrive krav til polygongeometri i modellen. Representerer et lukket areal (GM_Surface), som for eksempel omriss av kummer, fundamenter eller kulverter. Inkluderer beskrivelse av stedfestingskvalitet.</documentation>
		</annotation>
	</element>
	<complexType name="PolygongeometriType">
		<sequence>
			<element name="geometri" type="gml:SurfacePropertyType">
				<annotation>
					<documentation>Geometri: Geometrisk representasjon av et lukket areal (GM_Surface). Brukes for å vise flatebaserte objekter som omslutter en fysisk struktur.</documentation>
				</annotation>
			</element>
			<element name="posisjonskvalitet" type="ldb:PosisjonsKvalitetPropertyType">
				<annotation>
					<documentation>Posisjonskvalitet: Angir stedfestingskvalitet for polygonen, inkludert målemetode, nøyaktighet og synbarhet. Brukes til å vurdere hvor presist flategeometrien er kartlagt.</documentation>
				</annotation>
			</element>
		</sequence>
	</complexType>
	<complexType name="PolygongeometriPropertyType">
		<sequence>
			<element ref="ldb:Polygongeometri"/>
		</sequence>
	</complexType>
	<element name="PosisjonsKvalitet" type="ldb:PosisjonsKvalitetType" substitutionGroup="gml:AbstractObject">
		<annotation>
			<documentation>Beskrivelse av kvaliteten på stedfestingen til et objekt, inkludert både horisontal og vertikal målemetode, nøyaktighet og synbarhet. Klassen brukes for å dokumentere hvordan og hvor nøyaktig geometrien er registrert, og viderefører tradisjonelle kvalitetsattributter fra SOSI-standarden._x000D_
_x000D_
Merknad: Posisjonskvalitet er ikke konform med kvalitetsmodellen i ISO 19157:2013, men bygger på tidligere anvendte egenskaper i SOSI for praktisk bruk i kartdata.</documentation>
		</annotation>
	</element>
	<complexType name="PosisjonsKvalitetType">
		<sequence>
			<element name="målemetode" type="ldb:MålemetodeType">
				<annotation>
					<documentation>Målemetode: Metode eller instrument brukt for innmåling av horisontal posisjon (X/Y). Velges fra standardisert kodeliste.</documentation>
					<appinfo>
						<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Målemetode.gml</defaultCodeSpace>
					</appinfo>
				</annotation>
			</element>
			<element name="nøyaktighet" type="integer">
				<annotation>
					<documentation>Nøyaktighet: Horisontal nøyaktighet i centimeter, angitt som punktstandardavvik eller tverravvik. Brukes til å vurdere kvalitet i grunnriss (X/Y).</documentation>
				</annotation>
			</element>
			<element name="nøyaktighetHøyde" type="integer">
				<annotation>
					<documentation>Høydenøyaktighet: Vertikal nøyaktighet i centimeter. Dokumenterer presisjon i høyde (Z).</documentation>
				</annotation>
			</element>
			<element name="målemetodeHøyde" type="ldb:MålemetodeHøydeType">
				<annotation>
					<documentation>Målemetode høyde: Metode eller instrument brukt for måling av høyde (Z). Velges fra egen kodeliste.</documentation>
					<appinfo>
						<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_MålemetodeHøyde.gml</defaultCodeSpace>
					</appinfo>
				</annotation>
			</element>
			<element name="høydeReferanse" type="ldb:HøydereferanseType">
				<annotation>
					<documentation>Høydereferanse: Angir hvilken del av objektet høydeverdien refererer til (f.eks. topp, bunn eller senter). Velges fra kodeliste.</documentation>
					<appinfo>
						<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Høydereferanse.gml</defaultCodeSpace>
					</appinfo>
				</annotation>
			</element>
			<element name="innmålingsstatus" type="ldb:InnmålingsStatusType">
				<annotation>
					<documentation>Innmålingsstatus: Angir hvordan geometrien er etablert (innmålt, ikke innmålt eller importert) og gir informasjon om datakvalitet og opprinnelse. Velges fra kodeliste.</documentation>
					<appinfo>
						<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_InnmålingsStatus.gml</defaultCodeSpace>
					</appinfo>
				</annotation>
			</element>
			<element name="innmålingsdato" type="date">
				<annotation>
					<documentation>Innmålingsdato: Dato for innmåling eller registrering av geometri. Brukes til å vurdere datagrunnlagets aktualitet og kvalitet.</documentation>
				</annotation>
			</element>
			<element name="synbarhet" type="ldb:SynbarhetType">
				<annotation>
					<appinfo>
						<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_Synbarhet.gml</defaultCodeSpace>
					</appinfo>
				</annotation>
			</element>
		</sequence>
	</complexType>
