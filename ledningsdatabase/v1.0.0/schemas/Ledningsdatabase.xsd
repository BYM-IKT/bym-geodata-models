	<element name="Nettverkskomponent" type="ldb:NettverkskomponentType" abstract="true" substitutionGroup="gml:AbstractFeature">
		<annotation>
			<documentation>Abstrakt klasse som inneholder felles attributter for alle objekttyper i nettverksdatabasen. Representerer generell informasjon som navn, eierskap, status og identifikatorer som gjelder på tvers av nodetyper og føringsveier. Klassen skal ikke instansieres direkte, men arves av konkrete komponentklasser i modellen.</documentation>
		</annotation>
	</element>
	<complexType name="NettverkskomponentType" abstract="true">
		<complexContent>
			<extension base="gml:AbstractFeatureType">
				<sequence>
					<element name="navn" type="string" minOccurs="0">
						<annotation>
							<documentation>Navn: Angir en formell betegnelse eller identifikator som kan brukes til å navngi objektet i henhold til standarder eller eksterne krav._x000D_
Verdien er valgfri, men skal kun benyttes der det finnes et etablert navn eller nummer fra eksterne kilder (for eksempel prosjektdokumentasjon eller registre)._x000D_
Attributtet er ikke ment for plassering, merknader eller annen beskrivende informasjon.</documentation>
						</annotation>
					</element>
					<element name="merknad" type="string" minOccurs="0"/>
					<element name="fysiskPlassering" type="ldb:FysiskPlasseringType">
						<annotation>
							<documentation>Fysisk plassering: Angir hvor et objekt (feks. kum, fundament, detektor eller annet termineringspunkt) er fysisk plassert i terrenget eller infrastrukturen.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_FysiskPlassering.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="uuid" type="string" minOccurs="0">
						<annotation>
							<documentation>Objekt-ID: Universell unik identifikator (GUID) for objektet. Verdien genereres automatisk og sikrer global entydighet på tvers av systemer og databaser. Brukes til å koble objekter på tvers av datasett og forvaltningssystemer, og endres ikke selv om andre egenskaper ved objektet oppdateres.</documentation>
						</annotation>
					</element>
					<element name="trase" type="ldb:TrasePropertyType" minOccurs="0" maxOccurs="unbounded">
						<annotation>
							<appinfo>
								<reversePropertyName xmlns="http://www.opengis.net/gml/3.2">ldb:komponenter</reversePropertyName>
							</appinfo>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
