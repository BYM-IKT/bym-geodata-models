		</annotation>
		<restriction base="string">
			<enumeration value="tk1">
				<annotation>
					<documentation>Kvadratisk kumramme med ett kumlokk.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="tk2">
				<annotation>
					<documentation>Rektangulær kumramme</documentation>
				</annotation>
			</enumeration>
			<enumeration value="tk3">
				<annotation>
					<documentation>Rektangulær kumramme</documentation>
				</annotation>
			</enumeration>
			<enumeration value="sirkelformet">
				<annotation>
					<documentation>Sirkelformet / rund kumramme.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="oval">
				<annotation>
					<documentation>Oval kumramme, brukt der en trenger runde kjøresterke lokk.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="annet">
				<annotation>
					<documentation>Kumramme med form som ikke faller inn under de øvrige kategoriene. Beskriv i infofeltet</documentation>
				</annotation>
			</enumeration>
		</restriction>
