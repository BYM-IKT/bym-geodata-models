	<element name="Fremføringslinje" type="ldb:FremføringslinjeType" abstract="true" substitutionGroup="ldb:Føringsvei">
		<annotation>
			<documentation>Abstrakt klasse som inneholder felles egenskaper og relasjoner for linjeformede elementer i ledningsinfrastrukturen, som rør og trekkerør. Klassen legger til rette for felles struktur og modellering, og kan utvides med flere elementtyper som for eksempel kabler. Geometrien representerer senterlinjen til objektet i terrenget. Klassen skal ikke instansieres direkte, men arves av spesialiserte komponentklasser.</documentation>
		</annotation>
	</element>
	<complexType name="FremføringslinjeType" abstract="true">
		<complexContent>
			<extension base="ldb:FøringsveiType">
				<sequence>
					<element name="linje" type="ldb:LinjegeometriPropertyType">
						<annotation>
							<documentation>Linje: Geometrisk representasjon av fremføringslinjens senterlinje i terrenget. Brukes til kartvisning og nettverksanalyse, og inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
					<element name="iframfoeringsvei" type="ldb:FremføringsveiPropertyType" minOccurs="0"/>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="FremføringslinjePropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Fremføringslinje"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
	<element name="Fremføringsvei" type="ldb:FremføringsveiType" abstract="true" substitutionGroup="ldb:Føringsvei">
		<annotation>
			<documentation>Abstrakt klasse som inneholder felles egenskaper for fysiske føringsveier som kulverter, kanaler og grøfter. Representerer objekter med fysisk rom for kabler og rør, og definerer felles attributter for dimensjon, eierskap og utstrekning. Klassen skal ikke instansieres direkte, men arves av konkrete føringsveielementer.</documentation>
		</annotation>
	</element>
	<complexType name="FremføringsveiType" abstract="true">
		<complexContent>
			<extension base="ldb:FøringsveiType">
				<sequence>
					<element name="omriss" type="ldb:PolygongeometriPropertyType">
						<annotation>
							<documentation>Omriss: Flategeometri som viser fysisk utstrekning av føringsveien. Brukes til kartvisning og analyser. Inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
					<element name="ytreBredde" type="double" minOccurs="0">
						<annotation>
							<documentation>Ytre bredde: Total utvendig bredde på føringsveien, målt i meter. Inkluderer vegger eller ytre konstruksjoner.</documentation>
						</annotation>
					</element>
					<element name="ytreHøyde" type="double" minOccurs="0">
						<annotation>
							<documentation>Ytre høyde: Total høyde fra bunn til topp av konstruksjonen, oppgitt i meter.</documentation>
						</annotation>
					</element>
					<element name="antallRørEiesAvBYM" type="integer">
						<annotation>
							<documentation>Antall BYM-rør: Antall rør i føringsveien som eies av Bymiljøetaten. Oppgis som heltall.</documentation>
						</annotation>
					</element>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="FremføringsveiPropertyType">
