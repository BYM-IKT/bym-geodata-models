			<pattern value="other: \w{2,}"/>
		</restriction>
	</simpleType>
	<simpleType name="TrekkekumlokkTypeType">
		<annotation>
			<documentation>Angir formtype på kumlokk eller rist, for eksempel rund, kvadratisk eller delt. Verdien velges fra kodeliste.</documentation>
		</annotation>
		<union memberTypes="ldb:TrekkekumlokkTypeEnumerationType ldb:TrekkekumlokkTypeOtherType"/>
	</simpleType>
	<simpleType name="TrekkekumlokkTypeEnumerationType">
		<annotation>
			<documentation>Angir formtype på kumlokk eller rist, for eksempel rund, kvadratisk eller delt. Verdien velges fra kodeliste.</documentation>
		</annotation>
		<restriction base="string">
			<enumeration value="annet">
				<annotation>
					<documentation>Brukes når kumlokket har en form som ikke dekkes av de andre verdiene. Beskriv kumlokk form i infofeltet.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="eksentriskdelte">
				<annotation>
					<documentation>Kumlokk for stolpe, som er plassert eksentrisk i kum. Brukes for signalanlegg</documentation>
				</annotation>
			</enumeration>
			<enumeration value="kvadratisk">
				<annotation>
					<documentation>Kumlokk med firkantet form.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="sentriskdelte">
				<annotation>
					<documentation>Kumlokk for stolpe, som er plassert sentrisk i kum. Brukes for signalanlegg</documentation>
				</annotation>
			</enumeration>
			<enumeration value="sirkelformet">
				<annotation>
					<documentation>Kumlokk med rund form.</documentation>
				</annotation>
			</enumeration>
			<enumeration value="rektangulaer">
				<annotation>
					<documentation>Kumlokk med firkantet form.</documentation>
				</annotation>
			</enumeration>
		</restriction>
	</simpleType>
	<simpleType name="TrekkekumlokkTypeOtherType">
		<restriction base="string">
			<pattern value="other: \w{2,}"/>
		</restriction>
	</simpleType>
	<element name="Trekkekumramme" type="ldb:TrekkekumrammeType" substitutionGroup="gml:AbstractFeature">
		<annotation>
			<documentation>Trekkekumramme representerer ramme og lokk tilknyttet en trekkekum. Objektet beskriver den synlige delen av kummen i terrengnivå, inkludert ramme og lokk/rister. 
Kumrammen registreres med polygongeometri som representerer omriss av topp kumramme i horisontalplanet. Ulike ramme- og lokktyper registreres som egne egenskaper.</documentation>
		</annotation>
	</element>
	<complexType name="TrekkekumrammeType">
		<complexContent>
			<extension base="gml:AbstractFeatureType">
				<sequence>
					<element name="lokktype" type="ldb:TrekkekumlokkTypeType">
						<annotation>
							<documentation>Kumlokk: Angir formtype på kumlokk eller rist, for eksempel rund, kvadratisk eller delt. Verdien velges fra kodeliste.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_TrekkekumlokkType.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="trekkekumrammeform" type="ldb:TrekkekumrammeFormType">
						<annotation>
							<documentation>Kumrammeform: Angir form på kumrammen, for eksempel oval, kvadratisk eller TK1/TK2-ramme. Verdien velges fra kodeliste.</documentation>
							<appinfo>
								<defaultCodeSpace xmlns="http://www.opengis.net/gml/3.2">https://raw.githubusercontent.com/BYM-IKT/bym-geodata-models/refs/heads/master/ledningsdatabase/v1.0.0/codelists/ldb_TrekkekumrammeForm.gml</defaultCodeSpace>
							</appinfo>
						</annotation>
					</element>
					<element name="omriss" type="ldb:PolygongeometriPropertyType">
						<annotation>
							<documentation>Omriss: Flategeometri som representerer den totale fysiske utstrekningen av kumlokkrammen i horisontalplanet. Inkluderer posisjonskvalitet.</documentation>
						</annotation>
					</element>
					<element name="navn" type="string" minOccurs="0">
						<annotation>
							<documentation>Navn: Navn gitt til objektet i prosjekteringsgrunnlaget (IN-tegninger), for eksempel «BYM-01» eller «KM-01».</documentation>
						</annotation>
					</element>
					<element name="uuid" type="string" minOccurs="0">
						<annotation>
							<documentation>Objekt-ID: Universell unik identifikator (GUID) for objektet. Verdien genereres automatisk og sikrer global entydighet på tvers av systemer og databaser. Brukes til å koble objekter på tvers av datasett og forvaltningssystemer, og endres ikke selv om andre egenskaper ved objektet oppdateres.</documentation>
						</annotation>
					</element>
					<element name="bredde" type="double">
						<annotation>
							<documentation>Bredde: Objektets visuelle bredde i kart, oppgitt i meter. Brukes til å styre symbolbredde.</documentation>
						</annotation>
					</element>
					<element name="diameter" type="double">
						<annotation>
							<documentation>Diameter: Brukes ved sirkulær visning for å angi diameter i meter.</documentation>
						</annotation>
					</element>
					<element name="lengde" type="double">
						<annotation>
							<documentation>Lengde: Objektets visuelle lengde i kart, oppgitt i meter. Brukes til å skalere symboler i lengderetning.</documentation>
						</annotation>
					</element>
					<element name="høyde" type="double">
						<annotation>
							<documentation>Høyde: Objektets visuelle dybde eller høyde i vertikal retning, oppgitt i meter. Brukes til å representere tykkelse eller vertikal utstrekning i symbolisering.</documentation>
						</annotation>
					</element>
					<element name="merknad" type="string" minOccurs="0"/>
					<element name="tilknyttetKum" type="ldb:TrekkekumPropertyType" minOccurs="0"/>
				</sequence>
			</extension>
		</complexContent>
	</complexType>
	<complexType name="TrekkekumrammePropertyType">
		<sequence minOccurs="0">
			<element ref="ldb:Trekkekumramme"/>
		</sequence>
		<attributeGroup ref="gml:AssociationAttributeGroup"/>
		<attributeGroup ref="gml:OwnershipAttributeGroup"/>
	</complexType>
